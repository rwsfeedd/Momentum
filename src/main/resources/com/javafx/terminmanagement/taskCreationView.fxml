<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.Group?>
<?import javafx.scene.layout.HBox?>
<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.javafx.terminmanagement.Controllers.TaskCreationController">
    <center>
        <VBox>
            <!-- Eingabe Name -->
            <Label text="Name"/>
            <TextField fx:id="textfieldName" promptText="Name der Aufgabe"/>
            <!-- Eingabe Wiederholung -->
            <Label text="Wiederholung aller x Tage, wobei bei 0 keine Wiederholung auftritt"/>
            <TextField fx:id="textfieldRepeat" promptText="Eingabe von x Tagen"/>
            <!-- Eingabe Rollover -->
            <Label text="Rollover zu nächstem Tag"/>
            <HBox>
                <fx:define>
                    <ToggleGroup fx:id="groupButtonsRollover"/>
                </fx:define>
                <!--2 ToggleButtons für Rollover-->
                <RadioButton fx:id="buttonSetRollover" text="aktiviert"
                             toggleGroup="$groupButtonsRollover"/>
                <RadioButton text="deaktiviert"
                             toggleGroup="$groupButtonsRollover"
                             selected="true"
                />
            </HBox>
            <Label fx:id="validationLabel" textFill="red"/>
        </VBox>

    </center>
    <right>
        <VBox>
            <Button text="Speichern" onAction="#onSaveButtonClick"/>
            <Button text="Abbrechen" onAction="#onCancelButtonClick"/>
        </VBox>
    </right>
</BorderPane>
